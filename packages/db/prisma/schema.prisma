// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  merchants  Merchant[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Merchant {
  id                  String   @id @default(cuid())
  userId              String
  shopifyDomain       String   @unique
  shopifyAccessToken  String
  gorgiasSubdomain    String
  gorgiasApiKey       String
  gorgiasApiEmail     String
  displayName         String
  widgetPublicKey     String   @unique @default(cuid())
  widgetConfig        Json     @default("{\"position\":\"bottom-right\",\"primaryColor\":\"#4F6EF7\",\"greeting\":\"Hi! How can we help?\"}")
  syncStatus          SyncStatus @default(PENDING)
  lastSyncedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user               User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets            Ticket[]
  knowledgeChunks    KnowledgeChunk[]
  syncJobs           SyncJob[]
  subscription       Subscription?
  chatSessions       ChatSession[]
  notifications      Notification[]
  apiKeys            ApiKey[]

  @@index([userId])
  @@map("merchants")
}

enum SyncStatus {
  PENDING
  SYNCING
  READY
  ERROR
}

model Ticket {
  id              String   @id @default(cuid())
  merchantId      String
  gorgiasTicketId String
  subject         String
  messages        Json     @default("[]")
  tags            String[] @default([])
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, gorgiasTicketId])
  @@index([merchantId])
  @@map("tickets")
}

model KnowledgeChunk {
  id              String   @id @default(cuid())
  merchantId      String
  sourceType      ChunkSource
  sourceId        String?
  content         String   @db.Text
  embedding       Unsupported("vector(1536)")?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("knowledge_chunks")
}

enum ChunkSource {
  TICKET
  WEBSITE_CRAWL
  MANUAL
}

model SyncJob {
  id          String   @id @default(cuid())
  merchantId  String
  type        SyncType
  status      JobStatus @default(PENDING)
  progress    Int      @default(0)
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("sync_jobs")
}

enum SyncType {
  INITIAL_TICKETS
  WEEKLY_TICKETS
  WEBSITE_CRAWL
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ChatSession {
  id          String   @id @default(cuid())
  merchantId  String
  visitorId   String
  messages    Json     @default("[]")
  escalated   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([visitorId])
  @@map("chat_sessions")
}

model Subscription {
  id                   String   @id @default(cuid())
  merchantId           String   @unique
  stripeCustomerId     String   @unique
  stripeSubscriptionId String   @unique
  status               String
  planId               String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Notification {
  id          String   @id @default(cuid())
  merchantId  String
  title       String
  description String?
  type        String // "sync_complete", "new_chat", "payment_failed", "widget_install"
  read        Boolean  @default(false)
  actionUrl   String?  // URL to navigate to when clicked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([read])
  @@map("notifications")
}

model ApiKey {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  keyHash     String   @unique // sha256 hash of the actual key (never store raw key)
  keyPrefix   String   // First 4 chars of key for display (e.g., "rk_test_abc...")
  rateLimit   Int      @default(1000) // Requests per hour
  usageCount  Int      @default(0) // Total API calls made with this key
  lastUsedAt  DateTime? // When this key was last used
  createdAt   DateTime @default(now())
  revokedAt   DateTime? // Soft delete timestamp
  updatedAt   DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([revokedAt])
  @@map("api_keys")
}
