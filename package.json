{
  "name": "replybase",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered customer support chatbot for Shopify merchants",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "cd packages/db && npx prisma migrate dev",
    "db:push": "cd packages/db && npx prisma db push",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed": "cd packages/db && npx tsx prisma/seed.ts",
    "db:generate": "cd packages/db && npx prisma generate"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "turbo": "^1.10.16",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.15.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
