{
  "name": "replybase-dashboard",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rootDirectory": "apps/dashboard",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production",
    "NEXTAUTH_SECRET": "@secret",
    "NEXTAUTH_URL": "@api_url",
    "NEXT_PUBLIC_API_URL": "@api_url"
  }
}
